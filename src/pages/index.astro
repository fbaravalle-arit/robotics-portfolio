<script>
        function openModal(company, phase, description) {
            document.getElementById('modal-eyebrow').textContent = `${company} x ${phase}`;
            document.getElementById('modal-title').textContent = description;
            
            // Subtle dynamic image update placeholder based on category
            const imgAlt = `A highly detailed, practitioner-grade technical visualization representing ${description} for ${company} in an industrial setting, featuring sharp angles, warm steel tones, and precise engineering elements, suitable for a field protocol design system.`;
            document.getElementById('modal-image').setAttribute('data-alt', imgAlt);
            
            const modal = document.getElementById('project-modal');
            modal.classList.remove('hidden');
            document.body.style.overflow = 'hidden';
        }

        function closeModal() {
            const modal = document.getElementById('project-modal');
            modal.classList.add('hidden');
            document.body.style.overflow = 'auto';
        }
