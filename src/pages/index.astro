<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .fill-icon {
            font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        
        /* Custom Scanline Animation for Matrix Cells */
        @keyframes scanline {
            0% { top: 0; opacity: 0; }
            10% { opacity: 1; }
            90% { opacity: 1; }
            100% { top: 100%; opacity: 0; }
        }
        .matrix-cell-active:hover::before {
            content: '';
            position: absolute;
            left: 0;
            right: 0;
            height: 2px;
            background: theme('colors.secondary');
            animation: scanline 1.5s linear infinite;
            z-index: 10;
        }
        
        /* Grid System Override */
        .brutal-border {
            border: 1px solid theme('colors.outline');
        }
        .matrix-scroll-container::-webkit-scrollbar {
            height: 8px;
        }
        .matrix-scroll-container::-webkit-scrollbar-track {
            background: theme('colors.surface-container-low');
        }
        .matrix-scroll-container::-webkit-scrollbar-thumb {
            background: theme('colors.outline-variant');
        }
        
        body {
            background-color: theme('colors.background');
            color: theme('colors.on-background');
        }
    </style>
</head>
