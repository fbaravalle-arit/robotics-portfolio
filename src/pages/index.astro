---
import Layout from '../layouts/Layout.astro';
import Banner from '../components/Banner.astro';
import Matrix from '../components/Matrix.astro';
import Modal from '../components/Modal.astro';
---

<Layout title="Federico Baravalle — Engineering Lifecycle Portfolio">
  <Banner />

  <!-- HERO (full width) -->
  <section class="hero">
    <div class="hero__copy">
      <p class="bio__text type-body-md">
        Senior mechanical engineer with 6+ years designing and delivering
        electromechanical machinery under full regulatory compliance. Expert in
        mechanical design (CAD, FEA, DFMA), product lifecycle ownership from
        development, NPI to commissioning and sustaining. Delivered $10M+ projects
        from concept to production. Drove engineering continuous improvement program
        and led cross-functional teams, with results communicated to VP level.
        Experienced mentoring junior engineers. Hands-on software and data science
        practitioner.
      </p>
      <p class="bio__text type-body-md">
        I bring a collaborative, results-driven approach, with deep curiosity and
        commitment.
      </p>
    </div>
    <div class="stats">
      <div class="stat">
        <div class="stat__num type-headline-md">7+</div>
        <div class="stat__label type-label-caps">Years of Experience</div>
      </div>
      <div class="stat">
        <div class="stat__num type-headline-md">$10M+</div>
        <div class="stat__label type-label-caps">Project Value</div>
      </div>
      <div class="stat">
        <div class="stat__num type-headline-md">08/10</div>
        <div class="stat__label type-label-caps">Engineering systems life cycle phases</div>
      </div>
    </div>
  </section>

  <div class="rail-layout">
    <!-- Full-height left rail -->
    <aside class="rail">
      <span class="rail__label">Mechanical Engineering</span>
    </aside>

    <div class="rail-main">
      <!-- MATRIX -->
      <Matrix />
    </div>
  </div>

  <!-- FOOTER (full width) -->
  <footer class="footer">
    <div>
      <div class="footer__name type-label-caps">Federico Baravalle</div>
      <div class="footer__tag type-margin-note">Engineering, end to end. © 2026</div>
    </div>
    <div class="footer__links">
      <a class="type-label-caps" href="#">[LinkedIn]</a>
      <a class="type-label-caps" href="mailto:baravalle.fede@gmail.com">[Email]</a>
    </div>
  </footer>

  <Modal />
</Layout>
