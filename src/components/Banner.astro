---
// Full-width top banner — primary site identity + links.
import { Image } from 'astro:assets';
import linkedinIcon from '../assets/linkedin-icon.png';
import mixotIcon from '../assets/mixot-icon.png';
// GitHub icon stays a plain <img>: Astro's Image component passes SVGs through
// unoptimized, so there's no benefit to importing it.
---
<header class="banner">
  <a class="banner__title type-headline-md" href="/">Federico Baravalle</a>

  <nav class="banner__nav" aria-label="Links">
    <a class="banner__link type-body-sm" href="tel:+14708650179" aria-label="Phone: +1 470 865 01 79">
      <img class="banner__icon" src="/assets/cellphone-icon.svg" width="18" height="18" alt="" aria-hidden="true" />
      (470) 865 01 79
    </a>
    <a class="banner__link type-body-sm" href="https://www.linkedin.com/in/federico-baravalle/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn profile (opens in a new tab)">
      <Image class="banner__icon" src={linkedinIcon} width={18} height={18} loading="eager" alt="" aria-hidden="true" />
      LinkedIn
    </a>
    <a class="banner__link type-body-sm" href="https://github.com/fbaravalle-arit" target="_blank" rel="noopener noreferrer" aria-label="GitHub profile (opens in a new tab)">
      <img class="banner__icon" src="/assets/github-icon.svg" width="18" height="18" alt="" aria-hidden="true" />
      GitHub
    </a>
    <a class="banner__link type-body-sm" href="https://www.mixot.eu/" target="_blank" rel="noopener noreferrer" aria-label="MIXOT website (opens in a new tab)">
      <Image class="banner__icon" src={mixotIcon} width={18} height={18} loading="eager" alt="" aria-hidden="true" />
      MIXOT
    </a>
    <a class="banner__cta type-label-caps" href="mailto:baravalle.fede@gmail.com">Let's Chat</a>
  </nav>
</header>
