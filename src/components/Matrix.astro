---
import { phases, companies, statusMap, getCell } from '../data/matrixData.js';

const marker = { active: '●', partial: '◐' };
const phaseLabel = Object.fromEntries(phases.map((p) => [p.code, p.label]));

// Server-rendered details for every interactive cell. The modal injects this
// same copy via JS on click; rendering it statically (visually hidden) makes it
// readable by non-JS crawlers and AI agents without altering the visual UX.
const cellDetails = [];
for (const c of companies) {
  for (const p of phases) {
    const status = statusMap[c.id][p.code];
    if (status === 'inactive') continue;
    const cell = getCell(c.id, p.code);
    if (!cell.title) continue;
    cellDetails.push({
      company: c.name,
      phase: p.code,
      phaseLabel: phaseLabel[p.code],
      status,
      title: cell.title,
      description: cell.description,
      metrics: (cell.metrics || []).filter(Boolean),
    });
  }
}
---

<section class="matrix-section" id="lifecycle-matrix">
  <div class="matrix-head">
    <h2 class="type-headline-md">Engineering systems life cycle experience matrix</h2>
    <p class="type-body-md">Competence coverage through Engineering systems life cycle, mapped by company. Click on each cell to get more info!</p>
  </div>

  <div class="matrix-wrap">
    <div class="matrix-scroll">
      <div class="matrix" role="table" aria-label="Engineering lifecycle matrix">
        <!-- Header row: corner + company columns -->
        <div class="m-corner" role="columnheader">
          <span class="m-corner__label type-label-caps">Development life cycle phases</span>
        </div>
        {companies.map((c) => (
          <div class="m-company" role="columnheader">
            <h3 class="type-headline-md" set:html={c.displayName ?? c.name}></h3>
            <span class="type-margin-note">{c.years}</span>
          </div>
        ))}

        <!-- Phase rows -->
        {phases.map((p) => {
          const anyActive = companies.some((c) => statusMap[c.id][p.code] === 'active');
          return (
            <>
              <div class="m-phasehead" role="rowheader">
                <span class={`m-phasehead__code type-label-caps ${anyActive ? 'm-phasehead__code--active' : ''}`}>{p.code}</span>
                <span class="m-phasehead__label type-margin-note">{p.label}</span>
              </div>
              {companies.map((c) => {
                const status = statusMap[c.id][p.code];
                if (status === 'inactive') {
                  return <div class="cell cell--inactive" role="cell" aria-label={`${c.name} ${p.code} not covered`}></div>;
                }
                return (
                  <button
                    class={`cell cell--${status}`}
                    type="button"
                    data-company={c.id}
                    data-phase={p.code}
                    aria-label={`${c.name} ${p.code} — ${status}. Open detail.`}
                  >
                    <span class="marker">{marker[status]}</span>
                  </button>
                );
              })}
            </>
          );
        })}
      </div>
    </div>
  </div>

  <!-- Legend -->
  <div class="legend">
    <div class="legend__row"><span class="legend__mark">[●]</span><span class="type-body-sm">ACTIVE — direct project ownership</span></div>
    <div class="legend__row"><span class="legend__mark legend__mark--partial">[◐]</span><span class="type-body-sm">PARTIAL — adjacent or support role</span></div>
    <div class="legend__row"><span class="legend__mark legend__mark--inactive">[&nbsp;]</span><span class="type-body-sm">INACTIVE — not covered</span></div>
  </div>

  <!-- Static, visually-hidden transcript of every interactive cell's detail.
       Mirrors the modal copy so non-JS crawlers and AI agents can read it. -->
  <div class="sr-only">
    <h3>Engineering lifecycle matrix — project details</h3>
    {cellDetails.map((d) => (
      <article>
        <h4>{d.company} — {d.phase} {d.phaseLabel} ({d.status}): {d.title}</h4>
        <p>{d.description}</p>
        {d.metrics.length > 0 && (
          <ul>
            {d.metrics.map((m) => <li>{m}</li>)}
          </ul>
        )}
      </article>
    ))}
  </div>
</section>
