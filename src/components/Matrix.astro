---
import { phases, companies, statusMap } from '../data/matrixData.js';

const marker = { active: '●', partial: '◐' };
---

<section class="matrix-section" id="lifecycle-matrix">
  <div class="matrix-head">
    <p class="ref-tag ref-tag--active type-label-caps">[REF. 002 / LIFECYCLE]</p>
    <h2 class="type-headline-md">Engineering Lifecycle Matrix</h2>
    <p class="type-body-md">Capability coverage across the development lifecycle, mapped per organisation.</p>
  </div>

  <div class="matrix-wrap">
    <div class="matrix-scroll">
      <div class="matrix" role="table" aria-label="Engineering lifecycle matrix">
        <!-- Header row: corner + company columns -->
        <div class="m-corner" role="columnheader"></div>
        {companies.map((c) => (
          <div class="m-company" role="columnheader">
            <h3 class="type-headline-md">{c.name}</h3>
            <span class="type-margin-note">{c.sector} · {c.years}</span>
          </div>
        ))}

        <!-- Phase rows -->
        {phases.map((p) => {
          const anyActive = companies.some((c) => statusMap[c.id][p.code] === 'active');
          return (
            <>
              <div class="m-phasehead" role="rowheader">
                <span class={`m-phasehead__code type-label-caps ${anyActive ? 'm-phasehead__code--active' : ''}`}>{p.code}</span>
                <span class="m-phasehead__label type-margin-note">{p.label}</span>
              </div>
              {companies.map((c) => {
                const status = statusMap[c.id][p.code];
                if (status === 'inactive') {
                  return <div class="cell cell--inactive" role="cell" aria-label={`${c.name} ${p.code} not covered`}></div>;
                }
                return (
                  <button
                    class={`cell cell--${status}`}
                    role="cell"
                    type="button"
                    data-company={c.id}
                    data-phase={p.code}
                    aria-label={`${c.name} ${p.code} — ${status}. Open detail.`}
                  >
                    <span class="marker">{marker[status]}</span>
                  </button>
                );
              })}
            </>
          );
        })}
      </div>
    </div>
  </div>

  <!-- Legend -->
  <div class="legend">
    <div class="legend__row"><span class="legend__mark">[●]</span><span class="type-body-sm">ACTIVE — direct project ownership</span></div>
    <div class="legend__row"><span class="legend__mark legend__mark--partial">[◐]</span><span class="type-body-sm">PARTIAL — adjacent or support role</span></div>
    <div class="legend__row"><span class="legend__mark legend__mark--inactive">[&nbsp;]</span><span class="type-body-sm">INACTIVE — not covered</span></div>
  </div>
</section>
