---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'TPM in Physical AI & Robotics || Senior Mechanical Engineer || Portfolio',
} = Astro.props;

const ogImage = new URL('/assets/og-image.png', Astro.site ?? Astro.url).href;
const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url).href;
const siteUrl = (Astro.site ?? Astro.url).origin;

// Person structured data (JSON-LD). Rendered into the static HTML so AI agents
// and crawlers can read it without executing JavaScript.
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Federico Baravalle',
  jobTitle: 'TPM in Physical AI & Robotics / Senior Mechanical Engineer',
  description:
    'Technical Program Manager in Physical AI and Robotics, and Senior Mechanical Engineer with 6+ years in electromechanical systems, delivering projects up to $10M+ in scope with VP-level reporting and covering 8 of 10 engineering systems life cycle phases.',
  url: siteUrl,
  email: 'mailto:baravalle.fede@gmail.com',
  nationality: ['Italian', 'Argentinian'],
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Atlanta',
    addressRegion: 'GA',
    addressCountry: 'US',
  },
  sameAs: [
    'https://www.linkedin.com/in/federico-baravalle/',
    'https://github.com/fbaravalle-arit',
    'https://www.mixot.eu/',
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- Open Graph (link previews) -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Federico Baravalle" />

    <!-- Twitter / X card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Structured data: Person (JSON-LD, server-rendered) -->
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
  </head>
  <body>
    <slot />
  </body>
</html>
